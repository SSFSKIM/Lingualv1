          "sentence": "כמה זה עולה?",
          "masked_sentence": "כמה זה (__) ?",
          "answer": "עולה",
          "choices": ["עולה", "יורד", "שואל", "לוקח"],
          "explanation": "Use 'עולה' when asking how much something costs."
        },
        {
          "id": "GRAM-ORDER-HE-04",
          "sentence": "קפה אחד, בבקשה.",
          "masked_sentence": "קפה (__) , בבקשה.",
          "answer": "אחד",
          "choices": ["אחד", "שתיים", "מהר", "חדש"],
          "explanation": "Use 'אחד' to ask for one coffee."
