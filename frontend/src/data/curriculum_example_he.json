      "grammar_challenges": [
        {
          "id": "GRAM-GREET-HE-01",
          "sentence": "שלום, קוראים לי נועה.",
          "masked_sentence": "שלום, (__) לי נועה.",
          "answer": "קוראים",
          "choices": ["קוראים", "רואים", "שותים", "כותבים"],
          "explanation": "Use 'קוראים לי' in the phrase for saying your name."
        },
        {
          "id": "GRAM-GREET-HE-02",
          "sentence": "אני סטודנטית.",
          "masked_sentence": "(__) סטודנטית.",
          "answer": "אני",
          "choices": ["אני", "אתה", "הוא", "אנחנו"],
          "explanation": "Use 'אני' for 'I.'"
        },
        {
          "id": "GRAM-GREET-HE-03",
          "sentence": "נעים מאוד.",
          "masked_sentence": "נעים (__) .",
          "answer": "מאוד",
          "choices": ["מאוד", "מעט", "כאן", "מחר"],
          "explanation": "Use 'מאוד' to say 'very' in this greeting phrase."
        },
        {
          "id": "GRAM-GREET-HE-04",
          "sentence": "אני לומדת באוניברסיטה.",
          "masked_sentence": "אני לומדת (__) .",
          "answer": "באוניברסיטה",
          "choices": ["באוניברסיטה", "בבית", "מהר", "מחר"],
          "explanation": "Use 'באוניברסיטה' to say where you study."
        }
      ]
    },
