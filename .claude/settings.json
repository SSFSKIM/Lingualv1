{
  "permissions": {
    "allow": [
      "Bash"
    ],
    "deny": [
      "Read(./frontend/src/dataconnect-generated/**)",
      "Read(./archive/**)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/scripts/cloud-setup.sh\""
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "lingual-dev-agents": true,
    "cloud-sql-postgresql@claude-plugins-official": true
  }
}
