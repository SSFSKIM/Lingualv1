{
  "enabledPlugins": {
    "lingual-dev-agents": true
  },
  "permissions": {
    "allow": [
      "Bash"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/scripts/cloud-setup.sh\""
          }
        ]
      }
    ]
  }
}
