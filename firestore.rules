rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isUserOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function hasCurrentUserDoc() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function currentUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasActiveMembershipId() {
      return hasCurrentUserDoc()
        && currentUserData().last_active_membership_id is string
        && currentUserData().last_active_membership_id != '';
    }

    function activeMembershipData() {
      return get(
        /databases/$(database)/documents/memberships/$(currentUserData().last_active_membership_id)
      ).data;
    }

    function hasActiveMembership() {
      return hasActiveMembershipId()
        && exists(
          /databases/$(database)/documents/memberships/$(currentUserData().last_active_membership_id)
        );
    }

    function isActiveMembershipStatus(status) {
      return status in ['active', 'invited'];
    }

    function activeMembershipInOrg(orgId) {
      return hasActiveMembership()
        && isActiveMembershipStatus(activeMembershipData().status)
        && activeMembershipData().org_id == orgId;
    }

    function hasActiveRole(role) {
      return hasActiveMembership()
        && role in activeMembershipData().roles;
    }

    function classData(classId) {
      return get(/databases/$(database)/documents/classes/$(classId)).data;
    }

    function hasTeacherAccessToClass(classId) {
      return hasActiveMembership()
        && exists(/databases/$(database)/documents/classes/$(classId))
        && activeMembershipInOrg(classData(classId).org_id)
        && (
          hasActiveRole('school_admin')
          || currentUserData().last_active_membership_id in classData(classId).teacher_membership_ids
        );
    }

    function hasStudentEnrollmentForClass(classId) {
      return signedIn()
        && exists(/databases/$(database)/documents/enrollments/$(classId + '_' + request.auth.uid))
        && get(
          /databases/$(database)/documents/enrollments/$(classId + '_' + request.auth.uid)
        ).data.status == 'active';
    }

    match /users/{userId} {
      allow read, write: if isUserOwner(userId);

      match /{document=**} {
        allow read, write: if isUserOwner(userId);
      }
    }

    match /organizations/{orgId} {
      allow read: if activeMembershipInOrg(orgId);
      allow write: if false;
    }

    match /memberships/{membershipId} {
      allow read: if isUserOwner(resource.data.uid)
        || (
          resource.data.org_id is string
          && activeMembershipInOrg(resource.data.org_id)
          && hasActiveRole('school_admin')
        );
      allow write: if false;
    }

    match /classes/{classId} {
      allow read: if (
        resource.data.org_id is string
        && (
          hasTeacherAccessToClass(classId)
          || hasStudentEnrollmentForClass(classId)
        )
      );
      allow write: if false;
    }

    match /enrollments/{enrollmentId} {
      allow read: if isUserOwner(resource.data.student_uid)
        || (
          resource.data.class_id is string
          && hasTeacherAccessToClass(resource.data.class_id)
        );
      allow write: if false;
    }

    match /assignments/{assignmentId} {
      allow read: if resource.data.class_id is string
        && (
          hasTeacherAccessToClass(resource.data.class_id)
          || hasStudentEnrollmentForClass(resource.data.class_id)
        );
      allow write: if false;
    }

    match /student_compliance_records/{recordId} {
      allow read: if isUserOwner(resource.data.student_uid)
        || (
          resource.data.org_id is string
          && activeMembershipInOrg(resource.data.org_id)
          && (
            hasActiveRole('teacher')
            || hasActiveRole('school_admin')
          )
        );
      allow write: if false;
    }

    match /consent_events/{eventId} {
      allow read: if resource.data.org_id is string
        && activeMembershipInOrg(resource.data.org_id)
        && hasActiveRole('school_admin');
      allow write: if false;
    }

    match /deletion_requests/{requestId} {
      allow read: if resource.data.org_id is string
        && activeMembershipInOrg(resource.data.org_id)
        && hasActiveRole('school_admin');
      allow write: if false;
    }

    match /deletion_execution_runs/{runId} {
      allow read: if resource.data.org_id is string
        && activeMembershipInOrg(resource.data.org_id)
        && hasActiveRole('school_admin');
      allow write: if false;
    }

    match /school_creation_drafts/{uid} {
      allow read, write: if isUserOwner(uid);
    }

    match /teacher_join_requests/{requestId} {
      allow read: if request.auth != null
                  && (
                      resource.data.uid == request.auth.uid
                      || get(/databases/$(database)/documents/organizations/$(resource.data.org_id))
                          .data.school_admin_uids.hasAny([request.auth.uid])
                  );

      // Clients never write directly; backend admin SDK bypasses rules.
      allow write: if false;
    }

    match /outbox_emails/{emailId} {
      allow read, write: if false;  // service-account only; admin SDK bypasses
    }

    match /canvas_connections/{connectionId} {
      allow read, write: if false;
    }

    match /canvas_course_content/{contentId} {
      allow read: if resource.data.class_id is string
        && hasStudentEnrollmentForClass(resource.data.class_id);
      allow write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
