# Firebase Configuration
GOOGLE_CLOUD_PROJECT=lingu-480600

# Flask Configuration
FLASK_ENV=development
SECRET_KEY=<your-flask-secret-key-here>

# OpenAI API Key
OPENAI_API_KEY=<your-openai-api-key>

# Firebase Admin SDK
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# Azure Speech Services
AZURE_SPEECH_REGION=eastus
AZURE_SPEECH_KEY=<your-azure-speech-key>

# Canvas LMS Integration
CANVAS_PAT_ENCRYPTION_KEY=<your-canvas-pat-encryption-key>
CANVAS_INSTANCE_URL=https://your-school.instructure.com
CANVAS_ACCESS_TOKEN=<your-canvas-access-token>

# Resend (transactional email). Set in Cloud Functions runtime via Secret Manager.
# When unset, the outbox function logs the rendered email and marks docs 'sent_dev'.
RESEND_API_KEY=<your-resend-api-key>
RESEND_FROM_ADDRESS="Lingual <noreply@send.l1ngual.com>"

# Public base URL used in email CTA links.
PUBLIC_BASE_URL=https://l1ngual.com
